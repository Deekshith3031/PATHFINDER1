# PathFinder 10 - Environment Configuration
PORT=3000

# Secure Google Gemini API Key
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Web Client Configuration (Optional - fallback to localStorage if omitted)
# You can get these details from Firebase Console -> Project Settings -> General -> Web Apps
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
